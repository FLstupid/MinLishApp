# --- Gradle wrapper (keep jar; ignore local cache only via .gradle) ---

# --- Local SDK & secrets (never commit) ---
local.properties

# --- Firebase / Google (download from Firebase Console — do NOT commit) ---
**/google-services.json
GoogleService-Info.plist
**/serviceAccount*.json
**/*firebase*adminsdk*.json
firebase-debug.log
firebase-debug.*.log
ui-debug.log

# Keep template for teammates (commit the .example only)
!**/google-services.json.example

# --- IntelliJ / Android Studio (machine-local — do not commit) ---
*.iml
.idea/

# --- Cursor IDE (local rules, agent state — do not push to GitHub) ---
.cursor/

# --- Project docs (local / nộp riêng — không đẩy lên GitHub) ---
docs/

# --- Native / NDK ---
.externalNativeBuild/
.cxx/

# --- Captures, logs ---
/captures/
*.log

# --- OS ---
.DS_Store
Thumbs.db

